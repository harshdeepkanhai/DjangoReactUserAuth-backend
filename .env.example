# Copy to `.env` and fill in real values. Never commit the real .env.

# --- Django core ---------------------------------------------------------
# Local dev uses config.settings.local; production uses config.settings.production.
DJANGO_SETTINGS_MODULE=config.settings.local
# Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
DJANGO_SECRET_KEY=change-me-to-a-50-character-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_LOG_LEVEL=INFO

# --- CORS / CSRF (comma-separated origins) -------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# --- Database ------------------------------------------------------------
# Dev default is SQLite (used automatically if DATABASE_URL is unset).
# DATABASE_URL=sqlite:///db.sqlite3
# Production / docker-compose uses PostgreSQL:
DATABASE_URL=postgres://appuser:changeme@db:5432/appdb

# --- PostgreSQL (consumed by the docker-compose `db` service) ------------
POSTGRES_DB=appdb
POSTGRES_USER=appuser
POSTGRES_PASSWORD=changeme

# --- Production TLS hardening (optional overrides) ------------------------
# DJANGO_SECURE_SSL_REDIRECT=True
# DJANGO_SECURE_HSTS_SECONDS=31536000
